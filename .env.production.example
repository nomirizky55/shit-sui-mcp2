SHIT_MINT_CONFIG_ID=0x1167d03e5d967b8ca8c561e18021434b5acc6a7dc559609b83ca2459ed5a9836
MINT_FEE_MIST=1000000000

FEE_RECIPIENT=0xb2a1a32b7a16f4a4f788e4901276a88f7b370130f6f77ebe3cc94734dc2e8e99
LP_RECIPIENT=0xb2a1a32b7a16f4a4f788e4901276a88f7b370130f6f77ebe3cc94734dc2e8e99

# Production server should use a dedicated sponsor wallet, not your personal/admin wallet.
