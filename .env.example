SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# Bearer token expected in the MCP request Authorization header.
MCP_OAUTH_BEARER_TOKEN=replace-with-your-oauth-access-token

# Published Move package and shared mint config after deployment.
SUI_PACKAGE_ID=0x...
SHIT_MINT_CONFIG_ID=0x...

# 1 SUI mint fee, in MIST.
MINT_FEE_MIST=1000000000

# Address that receives mint fees.
FEE_RECIPIENT=0x...

# Address that receives the 500M SHIT LP allocation during MintConfig setup.
LP_RECIPIENT=0x...

# Optional sponsor signer for Codex-sponsored mint flows.
# Use either SPONSOR_PRIVATE_KEY, or a local Sui CLI keystore path + index.
SPONSOR_KEYSTORE_PATH=C:\Users\you\.sui\sui_config\sui.keystore
SPONSOR_KEYSTORE_INDEX=0
# SPONSOR_PRIVATE_KEY=suiprivkey...

# HTTP MCP server options.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
# Comma-separated host header allowlist, useful when binding to 0.0.0.0 behind a domain/reverse proxy.
# MCP_ALLOWED_HOSTS=your-domain.com,localhost
